{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe"],
    "chromeLaunchConfig": {
      "args": ["--no-sandbox"]
    },
    "hideElements": "svg text, .px-2.text-primary-500, .inline-block.rtl\\:rotate-180"
  },
  "urls": [
    {
      "url": "http://localhost:8080/",
      "ignore": ["color-contrast"]
    },
    "http://localhost:8080/about/",
    "http://localhost:8080/services/",
    "http://localhost:8080/services/cloud-infrastructure/",
    "http://localhost:8080/services/devsecops-devops/",
    "http://localhost:8080/services/cicd-automation/",
    "http://localhost:8080/services/kubernetes-containers/",
    "http://localhost:8080/services/infrastructure-as-code/",
    "http://localhost:8080/services/incident-response/",
    "http://localhost:8080/services/cloud-migration/",
    "http://localhost:8080/services/finops/",
    "http://localhost:8080/services/agile-coaching/",
    "http://localhost:8080/blog/",
    "http://localhost:8080/case-studies/",
    "http://localhost:8080/case-studies/saas-cloud-migration/",
    "http://localhost:8080/contact/",
    "http://localhost:8080/accessibility/"
  ]
}
